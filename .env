# Secret values below are 1Password references, not literal values - there
# are no secrets stored in this file, so it's safe to commit. Values are
# resolved at runtime via `op run --env-file .env -- <command>` (see
# scripts/infra.sh), which requires `op signin` first.

# Postgres (started via `docker compose up`); this default matches docker-compose.yml
# and is correct for anything running on the HOST (the API via `uvicorn`, pytest, psql).
# The `ingestion` container in docker-compose.yml overrides this to use the
# in-network hostname `db` instead of `localhost` - see docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://stockmoves:stockmoves@localhost:5432/stockmoves

# How often (seconds) the ingestion service refreshes already-tracked tickers.
# Only read by app/scheduler.py, not by the API.
INGESTION_INTERVAL_SECONDS=21600

# Required for the /api/chat endpoint
ANTHROPIC_API_KEY=op://technical-assessment-2026-07-06/local/Anthropic/API_KEY
# Optional, defaults to claude-sonnet-4-5
ANTHROPIC_MODEL=op://technical-assessment-2026-07-06/local/Anthropic/MODEL

# Optional: set this to activate industry moves news (industry/competitor
# articles via NewsAPI, on top of the always-on yfinance company news) -
# see app/news/newsapi_provider.py + app/news/classifier.py. Not required to
# run the app; without it, behavior is unchanged (Easy tier only).
NEWSAPI_API_KEY=op://technical-assessment-2026-07-06/local/add more/NEWSAPI_API_KEY
# Optional, unused - no GNews-backed provider is wired up (see README).
GNEWS_API_KEY=op://technical-assessment-2026-07-06/local/add more/GNEWS_API_KEY
